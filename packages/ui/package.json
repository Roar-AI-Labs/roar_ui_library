{
  "name": "@roar-workspace/ui",
  "version": "0.5.1",
  "description": "Roar Workspace React UI (Tailwind-first; see repo ROADMAP.md).",
  "license": "UNLICENSED",
  "keywords": [
    "react",
    "react-components",
    "design-system",
    "tailwindcss",
    "radix-ui",
    "sonner",
    "recharts",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roar-workspace/ui-monorepo.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/roar-workspace/ui-monorepo/issues"
  },
  "homepage": "https://www.npmjs.com/package/@roar-workspace/ui",
  "type": "module",
  "files": [
    "dist",
    "styles",
    "tailwind-preset.cjs",
    "skills"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./styles.css": "./styles/roar-tokens.css",
    "./tailwind-preset": "./tailwind-preset.cjs",
    "./tailwind-preset.cjs": "./tailwind-preset.cjs"
  },
  "sideEffects": [
    "**/*.css",
    "./styles/**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "tailwindcss": "^3.4.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "sonner": "^1.7.0",
    "recharts": "^2.15.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "sonner": "^1.7.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0"
  }
}
