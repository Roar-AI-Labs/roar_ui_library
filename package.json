{
  "name": "roar-workspace-ui-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @roar-workspace/ui",
    "build:playground": "npm run build -w @roar-workspace/playground",
    "build:gallery": "npm run build -w @roar-workspace/gallery",
    "build:docs": "npm run build -w @roar-workspace/ui && npm run build -w @roar-workspace/docs",
    "dev:ui": "npm run dev -w @roar-workspace/ui",
    "dev:playground": "npm run dev -w @roar-workspace/playground",
    "dev:gallery": "npm run dev -w @roar-workspace/gallery",
    "dev:docs": "npm run build -w @roar-workspace/ui && npm run dev -w @roar-workspace/docs"
  },
  "engines": {
    "node": ">=18"
  }
}
